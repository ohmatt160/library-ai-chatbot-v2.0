    "    \"        \\\"You can renew books online or at the circulation desk.\\\",\\n\",\n",
    "    \"    ],\\n\",\n",
    "    \"    'library_info': [\\n\",\n",
    "    \"        \\\"Our library offers WiFi, study rooms, printing services, and e-book access.\\\",\\n\",\n",
    "    \"        \\\"We provide various services including database access, interlibrary loans, and events.\\\",\\n\",\n",
    "    \"        \\\"The library has 5 study rooms, 20 computer stations, and free WiFi.\\\",\\n\",\n",
    "    \"    ],\\n\",\n",
    "    \"    'account': [\\n\",\n",
    "    \"        \\\"To get a library card, visit the front desk with a valid ID.\\\",\\n\",\n",
    "    \"        \\\"You can reset your password through our online portal.\\\",\\n\",\n",
    "    \"        \\\"I can help you with your account. What would you like to update?\\\",\\n\",\n",
    "    \"    ],\\n\",\n",
    "    \"    'hours': [\\n\",\n",
    "    \"        \\\"Our library is open Monday-Friday 9AM-8PM, Saturday 10AM-6PM, Sunday 12PM-5PM.\\\",\\n\",\n",
    "    \"        \\\"We're open on weekends! Saturday 10-6, Sunday 12-5.\\\",\\n\",\n",
    "    \"        \\\"Check our holiday schedule - we're closed on major holidays.\\\",\\n\",\n",
    "    \"    ],\\n\",\n",
    "    \"    'identity': [\\n\",\n",
    "    \"        \\\"I'm the Library AI Assistant! I can help you find books, check availability, and answer questions about our library services.\\\",\\n\",\n",
    "    \"        \\\"I'm an AI chatbot designed to help you navigate our library's resources. I can search for books, check your account, and provide information about our services.\\\",\\n\",\n",
    "    \"        \\\"Hello! I'm here to help you with library services - from finding books to checking your account!\\\",\\n\",\n",
    "    \"    ],\\n\",\n",
    "    \"}\\n\",\n",
    "    \"\\n\",\n",
    "    \"import random\\n\",\n",
    "    \"\\n\",\n",
    "    \"def generate_response(intent):\\n\",\n",
    "    \"    \\\"\\\"\\\"Generate a response based on intent\\\"\\\"\\\"\\n\",\n",
    "    \"    templates = response_templates.get(intent, [\\\"I'm not sure how to help with that.\\\"])\\n\",\n",
    "    \"    return random.choice(templates)\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(\\\"=\\\" * 60)\\n\",\n",
    "    \"print(\\\"RESPONSE GENERATION\\\")\\n\",\n",
    "    \"print(\\\"=\\\" * 60)\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(\\\"\\\\n💬 Sample Responses by Intent:\\\")\\n\",\n",
    "    \"print(\\\"-\\\" * 60)\\n\",\n",
    "    \"for intent in response_templates.keys():\\n\",\n",
    "    \"    response = generate_response(intent)\\n\",\n",
    "    \"    print(f\\\"\\\\n🎯 Intent: {intent}\\\")\\n\",\n",
    "    \"    print(f\\\"   💬 Response: {response[:70]}...\\\")\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## Cell 11: Complete End-to-End Pipeline Demo\\n\",\n",
    "    \"\\n\",\n",
    "    \"This cell demonstrates the **complete pipeline** from user query to final response.\\n\",\n",
    "    \"\\n\",\n",
    "    \"### Step-by-Step Flow:\\n\",\n",
    "    \"1. User Input → 2. Preprocessing → 3. Hybrid Classification → 4. Response Generation → 5. Output\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"# Complete end-to-end pipeline demonstration\\n\",\n",
    "    \"\\n\",\n",
    "    \"def process_query(query):\\n\",\n",
    "    \"    \\\"\\\"\\\"\\n\",\n",
    "    \"    Complete query processing pipeline:\\n\",\n",
    "    \"    1. Preprocess\\n\",\n",
    "    \"    2. Classify (hybrid)\\n\",\n",
