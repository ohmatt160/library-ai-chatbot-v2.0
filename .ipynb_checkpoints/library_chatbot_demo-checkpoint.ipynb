    "    \"    # Library Info Intent\\n\",\n",
    "    \"    (\\\"Tell me about your library\\\", \\\"library_info\\\"),\\n\",\n",
    "    \"    (\\\"What services does the library offer\\\", \\\"library_info\\\"),\\n\",\n",
    "    \"    (\\\"Do you have WiFi access\\\", \\\"library_info\\\"),\\n\",\n",
    "    \"    (\\\"Can I print documents here\\\", \\\"library_info\\\"),\\n\",\n",
    "    \"    (\\\"Do you have study rooms\\\", \\\"library_info\\\"),\\n\",\n",
    "    \"    (\\\"What databases are available\\\", \\\"library_info\\\"),\\n\",\n",
    "    \"    (\\\"Can I access e-books\\\", \\\"library_info\\\"),\\n\",\n",
    "    \"    (\\\"What events does the library host\\\", \\\"library_info\\\"),\\n\",\n",
    "    \"    \\n\",\n",
    "    \"    # Account Intent\\n\",\n",
    "    \"    (\\\"How do I get a library card\\\", \\\"account\\\"),\\n\",\n",
    "    \"    (\\\"I forgot my password\\\", \\\"account\\\"),\\n\",\n",
    "    \"    (\\\"How do I renew my membership\\\", \\\"account\\\"),\\n\",\n",
    "    \"    (\\\"Update my contact information\\\", \\\"account\\\"),\\n\",\n",
    "    \"    (\\\"Check my account status\\\", \\\"account\\\"),\\n\",\n",
    "    \"    (\\\"How do I update my email\\\", \\\"account\\\"),\\n\",\n",
