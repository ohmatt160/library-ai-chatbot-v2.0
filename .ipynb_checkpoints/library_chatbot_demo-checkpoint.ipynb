    "    \"    (\\\"How do I borrow a book\\\", \\\"borrow\\\"),\\n\",\n",
    "    \"    (\\\"I want to check out this book\\\", \\\"borrow\\\"),\\n\",\n",
    "    \"    (\\\"Can I reserve The Catcher in the Rye\\\", \\\"borrow\\\"),\\n\",\n",
