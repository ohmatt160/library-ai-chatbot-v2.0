    "    \"        \\\"Let me check the availability for you...\\\",\\n\",\n",
    "    \"        \\\"I'll look up that book's status right away.\\\",\\n\",\n",
    "    \"        \\\"Checking our inventory...\\\",\\n\",\n",
    "    \"    ],\\n\",\n",
    "    \"    'borrow': [\\n\",\n",
    "    \"        \\\"To borrow a book, you can use our online catalog or visit the library.\\\",\\n\",\n",
    "    \"        \\\"I can help you reserve that book. Here's how to borrow:\\\",\\n\",\n",
    "    \"        \\\"Our borrowing period is typically 2 weeks. Would you like to proceed?\\\",\\n\",\n",
    "    \"    ],\\n\",\n",
