    "    \"    (\\\"What are your opening hours\\\", \\\"hours\\\"),\\n\",\n",
    "    \"    (\\\"When does the library close\\\", \\\"hours\\\"),\\n\",\n",
    "    \"    (\\\"Are you open on weekends\\\", \\\"hours\\\"),\\n\",\n",
    "    \"    (\\\"What time do you open tomorrow\\\", \\\"hours\\\"),\\n\",\n",
    "    \"    (\\\"Is the library open today\\\", \\\"hours\\\"),\\n\",\n",
    "    \"    (\\\"Holiday hours\\\", \\\"hours\\\"),\\n\",\n",
    "    \"    (\\\"Late night hours\\\", \\\"hours\\\"),\\n\",\n",
    "    \"    (\\\"When are you open on Sundays\\\", \\\"hours\\\"),\\n\",\n",
    "    \"    \\n\",\n",
    "    \"    # Identity Intent (from Chapter 3)\\n\",\n",
    "    \"    (\\\"Who are you\\\", \\\"identity\\\"),\\n\",\n",
    "    \"    (\\\"What is your name\\\", \\\"identity\\\"),\\n\",\n",
    "    \"    (\\\"Are you a bot\\\", \\\"identity\\\"),\\n\",\n",
    "    \"    (\\\"Tell me about yourself\\\", \\\"identity\\\"),\\n\",\n",
    "    \"    (\\\"What can you help me with\\\", \\\"identity\\\"),\\n\",\n",
    "    \"    (\\\"Who created you\\\", \\\"identity\\\"),\\n\",\n",
    "    \"    (\\\"What are your capabilities\\\", \\\"identity\\\"),\\n\",\n",
    "    \"    (\\\"Explain what you do\\\", \\\"identity\\\")\\n\",\n",
    "    \"]\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Separate into texts and labels\\n\",\n",
    "    \"texts, labels = zip(*training_data)\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(\\\"=\\\" * 60)\\n\",\n",
    "    \"print(\\\"TRAINING DATA CREATED\\\")\\n\",\n",
    "    \"print(\\\"=\\\" * 60)\\n\",\n",
    "    \"print(f\\\"Total training samples: {len(texts)}\\\")\\n\",\n",
    "    \"print(f\\\"\\\\nIntent distribution:\\\")\\n\",\n",
    "    \"for intent, count in Counter(labels).items():\\n\",\n",
    "    \"    print(f\\\"  - {intent}: {count} samples\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(\\\"\\\\n📚 Sample data points:\\\")\\n\",\n",
    "    \"for i in range(3):\\n\",\n",
    "    \"    print(f\\\"  Text: '{texts[i]}'\\\")\\n\",\n",
    "    \"    print(f\\\"  Intent: {labels[i]}\\\")\\n\",\n",
    "    \"    print()\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## Cell 3: Text Preprocessing - Tokenization\\n\",\n",
    "    \"\\n\",\n",
    "    \"**Text preprocessing** is crucial for NLP. We convert raw text into tokens that the model can understand.\\n\",\n",
    "    \"\\n\",\n",
    "    \"### Steps:\\n\",\n",
    "    \"1. **Lowercasing** - Convert to lowercase for consistency\\n\",\n",
    "    \"2. **Tokenization** - Split text into individual words (tokens)\\n\",\n",
    "    \"3. **Punctuation removal** - Remove special characters\\n\",\n",
    "    \"\\n\",\n",
    "    \"This follows the preprocessing pipeline described in Chapter 3, Section 3.2.\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"# Step 1: Text Preprocessing Functions\\n\",\n",
    "    \"\\n\",\n",
    "    \"def preprocess_text(text):\\n\",\n",
    "    \"    \\\"\\\"\\\"\\n\",\n",
    "    \"    Complete preprocessing pipeline:\\n\",\n",
    "    \"    1. Lowercase\\n\",\n",
    "    \"    2. Remove punctuation\\n\",\n",
    "    \"    3. Tokenize\\n\",\n",
    "    \"    4. Remove stopwords\\n\",\n",
    "    \"    5. Lemmatize\\n\",\n",
    "    \"    \\\"\\\"\\\"\\n\",\n",
    "    \"    # 1. Lowercase\\n\",\n",
    "    \"    text = text.lower()\\n\",\n",
    "    \"    \\n\",\n",
    "    \"    # 2. Remove punctuation (keep only letters and spaces)\\n\",\n",
    "    \"    text = re.sub(r'[^a-zA-Z\\\\s]', '', text)\\n\",\n",
    "    \"    \\n\",\n",
    "    \"    # 3. Tokenize\\n\",\n",
    "    \"    tokens = word_tokenize(text)\\n\",\n",
    "    \"    \\n\",\n",
    "    \"    # 4. Remove stopwords\\n\",\n",
    "    \"    stop_words = set(stopwords.words('english'))\\n\",\n",
    "    \"    tokens = [t for t in tokens if t not in stop_words]\\n\",\n",
    "    \"    \\n\",\n",
    "    \"    # 5. Lemmatize (reduce words to base form)\\n\",\n",
    "    \"    lemmatizer = WordNetLemmatizer()\\n\",\n",
    "    \"    tokens = [lemmatizer.lemmatize(t) for t in tokens]\\n\",\n",
    "    \"    \\n\",\n",
    "    \"    return tokens\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Demonstrate preprocessing on sample texts\\n\",\n",
    "    \"print(\\\"=\\\" * 60)\\n\",\n",
    "    \"print(\\\"TEXT PREPROCESSING DEMO\\\")\\n\",\n",
    "    \"print(\\\"=\\\" * 60)\\n\",\n",
    "    \"\\n\",\n",
    "    \"sample_texts = [\\n\",\n",
    "    \"    \\\"I want to find a book about Python programming\\\",\\n\",\n",
    "    \"    \\\"Are you open on weekends?\\\",\\n\",\n",
    "    \"    \\\"Can I borrow Clean Code today?\\\",\\n\",\n",
    "    \"    \\\"Who are you?\\\"\\n\",\n",
    "    \"]\\n\",\n",
    "    \"\\n\",\n",
    "    \"for text in sample_texts:\\n\",\n",
    "    \"    tokens = preprocess_text(text)\\n\",\n",
    "    \"    print(f\\\"\\\\n📝 Original: '{text}'\\\")\\n\",\n",
    "    \"    print(f\\\"🔤 Tokens: {tokens}\\\")\\n\",\n",
    "    \"    print(f\\\"📊 Token count: {len(tokens)}\\\")\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## Cell 4: Feature Extraction - Bag of Words (BoW)\\n\",\n",
    "    \"\\n\",\n",
    "    \"**Bag-of-Words** converts text into numerical features. Each document becomes a vector of word counts.\\n\",\n",
    "    \"\\n\",\n",
    "    \"This is described in Chapter 3, Section 3.3 (Feature Engineering).\\n\",\n",
    "    \"\\n\",\n",
    "    \"### How BoW works:\\n\",\n",
    "    \"1. Create vocabulary from all unique words\\n\",\n",
    "    \"2. For each document, count occurrences of each vocabulary word\\n\",\n",
    "    \"3. Result: Sparse matrix where rows=documents, columns=vocabulary words\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"# Apply preprocessing to all training data\\n\",\n",
    "    \"processed_texts = [' '.join(preprocess_text(t)) for t in texts]\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Create Bag-of-Words vectorizer\\n\",\n",
    "    \"bow_vectorizer = CountVectorizer(max_features=100, min_df=1)\\n\",\n",
    "    \"bow_matrix = bow_vectorizer.fit_transform(processed_texts)\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(\\\"=\\\" * 60)\\n\",\n",
    "    \"print(\\\"BAG-OF-WORDS FEATURE EXTRACTION\\\")\\n\",\n",
    "    \"print(\\\"=\\\" * 60)\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(f\\\"\\\\n📊 Feature Matrix Shape: {bow_matrix.shape}\\\")\\n\",\n",
    "    \"print(f\\\"   - Rows (documents): {bow_matrix.shape[0]}\\\")\\n\",\n",
    "    \"print(f\\\"   - Columns (vocabulary size): {bow_matrix.shape[1]}\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Show vocabulary\\n\",\n",
    "    \"vocabulary = bow_vectorizer.get_feature_names_out()\\n\",\n",
    "    \"print(f\\\"\\\\n📚 Vocabulary (first 20 words):\\\")\\n\",\n",
    "    \"print(f\\\"   {list(vocabulary[:20])}\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Show a sample BoW vector\\n\",\n",
    "    \"print(f\\\"\\\\n📝 Sample BoW vector (first document):\\\")\\n\",\n",
    "    \"sample_vector = bow_matrix[0].toarray()[0]\\n\",\n",
    "    \"non_zero = [(vocabulary[i], sample_vector[i]) for i in range(len(sample_vector)) if sample_vector[i] > 0]\\n\",\n",
    "    \"print(f\\\"   {dict(non_zero)}\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Display as sparse matrix visualization\\n\",\n",
    "    \"print(f\\\"\\\\n🔢 Sparse Matrix (showing non-zero values per row):\\\")\\n\",\n",
    "    \"for i in range(min(5, bow_matrix.shape[0])):\\n\",\n",
    "    \"    row = bow_matrix[i].toarray()[0]\\n\",\n",
    "    \"    non_zero_count = sum(1 for x in row if x > 0)\\n\",\n",
    "    \"    print(f\\\"   Document {i+1}: {non_zero_count} non-zero features\\\")\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## Cell 5: Feature Extraction - TF-IDF\\n\",\n",
    "    \"\\n\",\n",
    "    \"**TF-IDF (Term Frequency-Inverse Document Frequency)** is an improvement over BoW.\\n\",\n",
    "    \"\\n\",\n",
    "    \"### Why TF-IDF?\\n\",\n",
    "    \"- **TF (Term Frequency)**: How often a word appears in a document\\n\",\n",
    "    \"- **IDF (Inverse Document Frequency)**: How rare/common the word is across all documents\\n\",\n",
    "    \"\\n\",\n",
    "    \"This gives higher weight to distinguishing words and lower weight to common words.\\n\",\n",
    "    \"\\n\",\n",
    "    \"Formula: `TF-IDF = TF × log(N / DF)`\\n\",\n",
    "    \"Where N = total documents, DF = documents containing the word\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"# Create TF-IDF vectorizer\\n\",\n",
    "    \"tfidf_vectorizer = TfidfVectorizer(max_features=100, min_df=1)\\n\",\n",
    "    \"tfidf_matrix = tfidf_vectorizer.fit_transform(processed_texts)\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(\\\"=\\\" * 60)\\n\",\n",
    "    \"print(\\\"TF-IDF FEATURE EXTRACTION\\\")\\n\",\n",
    "    \"print(\\\"=\\\" * 60)\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(f\\\"\\\\n📊 TF-IDF Matrix Shape: {tfidf_matrix.shape}\\\")\\n\",\n",
    "    \"print(f\\\"   - Rows (documents): {tfidf_matrix.shape[0]}\\\")\\n\",\n",
    "    \"print(f\\\"   - Columns (vocabulary size): {tfidf_matrix.shape[1]}\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Compare BoW vs TF-IDF for a specific word\\n\",\n",
    "    \"test_word = 'book'\\n\",\n",
    "    \"if test_word in vocabulary:\\n\",\n",
    "    \"    idx = list(vocabulary).index(test_word)\\n\",\n",
    "    \"    print(f\\\"\\\\n📈 Comparison for '{test_word}':\\\")\\n\",\n",
    "    \"    print(f\\\"   BoW:   {bow_matrix[0, idx]}\\\")\\n\",\n",
    "    \"    print(f\\\"   TF-IDF: {tfidf_matrix[0, idx]:.4f}\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Show TF-IDF scores for first document\\n\",\n",
    "    \"print(f\\\"\\\\n🔢 TF-IDF scores (first document, top features):\\\")\\n\",\n",
    "    \"sample_tfidf = tfidf_matrix[0].toarray()[0]\\n\",\n",
    "    \"top_indices = sample_tfidf.argsort()[-5:][::-1]\\n\",\n",
    "    \"for idx in top_indices:\\n\",\n",
    "    \"    if sample_tfidf[idx] > 0:\\n\",\n",
    "    \"        print(f\\\"   {vocabulary[idx]}: {sample_tfidf[idx]:.4f}\\\")\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## Cell 6: Model Training - Intent Classification\\n\",\n",
    "    \"\\n\",\n",
    "    \"Now we train a **Naive Bayes classifier** for intent classification. This is the ML component of our hybrid system.\\n\",\n",
    "    \"\\n\",\n",
    "    \"### Model Choice: Multinomial Naive Bayes\\n\",\n",
    "    \"- Works well with text classification\\n\",\n",
    "    \"- Fast training and prediction\\n\",\n",
    "    \"- Handles multi-class classification\\n\",\n",
    "    \"\\n\",\n",
    "    \"Split: 80% training, 20% testing\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"# Split data into training and testing sets\\n\",\n",
    "    \"X_train, X_test, y_train, y_test = train_test_split(\\n\",\n",
    "    \"    tfidf_matrix, \\n\",\n",
    "    \"    labels, \\n\",\n",
    "    \"    test_size=0.2, \\n\",\n",
    "    \"    random_state=42,\\n\",\n",
    "    \"    stratify=labels\\n\",\n",
    "    \")\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Train Naive Bayes classifier\\n\",\n",
    "    \"classifier = MultinomialNB()\\n\",\n",
    "    \"classifier.fit(X_train, y_train)\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Make predictions on test set\\n\",\n",
    "    \"y_pred = classifier.predict(X_test)\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(\\\"=\\\" * 60)\\n\",\n",
    "    \"print(\\\"MODEL TRAINING - INTENT CLASSIFICATION\\\")\\n\",\n",
    "    \"print(\\\"=\\\" * 60)\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(f\\\"\\\\n📊 Dataset Split:\\\")\\n\",\n",
    "    \"print(f\\\"   Training samples: {X_train.shape[0]}\\\")\\n\",\n",
    "    \"print(f\\\"   Testing samples: {X_test.shape[0]}\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(f\\\"\\\\n🎯 Model: Multinomial Naive Bayes\\\")\\n\",\n",
    "    \"print(f\\\"   Classes learned: {list(classifier.classes_)}\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Show predictions vs actual\\n\",\n",
    "    \"print(f\\\"\\\\n📝 Sample Predictions (Test Set):\\\")\\n\",\n",
    "    \"print(\\\"-\\\" * 60)\\n\",\n",
    "    \"for i in range(min(8, len(y_test))):\\n\",\n",
    "    \"    status = \\\"✅\\\" if y_pred[i] == y_test[i] else \\\"❌\\\"\\n\",\n",
    "    \"    print(f\\\"{status} Input: '{texts[i][:40]}...'\\\")\\n\",\n",
    "    \"    print(f\\\"   Predicted: {y_pred[i]} | Actual: {y_test[i]}\\\")\\n\",\n",
    "    \"    print()\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## Cell 7: Model Evaluation - F1-Score Calculation\\n\",\n",
    "    \"\\n\",\n",
    "    \"This is a critical part of **Chapter 3: Evaluation Metrics**.\\n\",\n",
    "    \"\\n\",\n",
    "    \"### Metrics Used:\\n\",\n",
    "    \"- **Precision**: Of all predicted positives, how many are correct?\\n\",\n",
    "    \"- **Recall**: Of all actual positives, how many did we find?\\n\",\n",
    "    \"- **F1-Score**: Harmonic mean of Precision and Recall (balance)\\n\",\n",
    "    \"- **Accuracy**: Overall correct predictions\\n\",\n",
    "    \"\\n\",\n",
    "    \"Formula: `F1 = 2 × (Precision × Recall) / (Precision + Recall)`\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"# Calculate evaluation metrics\\n\",\n",
    "    \"accuracy = (y_pred == y_test).mean()\\n\",\n",
    "    \"f1 = f1_score(y_test, y_pred, average='weighted')\\n\",\n",
    "    \"precision = precision_score(y_test, y_pred, average='weighted')\\n\",\n",
    "    \"recall = recall_score(y_test, y_pred, average='weighted')\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(\\\"=\\\" * 60)\\n\",\n",
    "    \"print(\\\"MODEL EVALUATION - PERFORMANCE METRICS\\\")\\n\",\n",
    "    \"print(\\\"=\\\" * 60)\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(f\\\"\\\\n📊 OVERALL METRICS:\\\")\\n\",\n",
    "    \"print(f\\\"   ╔══════════════════════════════════╗\\\")\\n\",\n",
    "    \"print(f\\\"   ║ Accuracy:  {accuracy:.2%}             ║\\\")\\n\",\n",
    "    \"print(f\\\"   ║ Precision: {precision:.2%}             ║\\\")\\n\",\n",
    "    \"print(f\\\"   ║ Recall:    {recall:.2%}             ║\\\")\\n\",\n",
    "    \"print(f\\\"   ║ F1-Score:  {f1:.2%}             ║\\\")\\n\",\n",
    "    \"print(f\\\"   ╚══════════════════════════════════╝\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Per-class breakdown\\n\",\n",
    "    \"print(f\\\"\\\\n📈 PER-CLASS F1-SCORES:\\\")\\n\",\n",
    "    \"print(\\\"-\\\" * 60)\\n\",\n",
    "    \"report = classification_report(y_test, y_pred)\\n\",\n",
    "    \"print(report)\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Detailed F1 calculation for each class\\n\",\n",
    "    \"from sklearn.metrics import precision_recall_fscore_support\\n\",\n",
    "    \"\\n\",\n",
    "    \"p, r, f1_per_class, _ = precision_recall_fscore_support(y_test, y_pred, average=None)\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(\\\"\\\\n🎯 Individual Intent Performance:\\\")\\n\",\n",
    "    \"for i, cls in enumerate(classifier.classes_):\\n\",\n",
    "    \"    print(f\\\"   {cls:15} | Precision: {p[i]:.2f} | Recall: {r[i]:.2f} | F1: {f1_per_class[i]:.2f}\\\")\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## Cell 8: Rule-Based Matching Demo\\n\",\n",
    "    \"\\n\",\n",
    "    \"The **Rule Engine** handles specific patterns that require exact matching.\\n\",\n",
    "    \"\\n\",\n",
    "    \"### Why Rules?\\n\",\n",
    "    \"- Handle patterns that ML might miss\\n\",\n",
    "    \"- Fast and deterministic\\n\",\n",
    "    \"- Useful for common queries with specific formats\\n\",\n",
    "    \"\\n\",\n",
    "    \"This is the Rules component from our Hybrid Architecture (Chapter 3, Section 3.4).\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"# Rule-based pattern matching\\n\",\n",
    "    \"# These patterns are checked before/alongside ML classification\\n\",\n",
    "    \"\\n\",\n",
    "    \"class RuleEngine:\\n\",\n",
    "    \"    \\\"\\\"\\\"Simple rule-based matcher for library queries\\\"\\\"\\\"\\n\",\n",
    "    \"    \\n\",\n",
    "    \"    def __init__(self):\\n\",\n",
    "    \"        self.rules = {\\n\",\n",
    "    \"            # Book search patterns\\n\",\n",
    "    \"            r'(?:search|find|look for)\\\\s+(.+?)(?:book|novel)': 'book_search',\\n\",\n",
    "    \"            r'(?:book|novel)\\\\s+by\\\\s+([A-Za-z\\\\s]+)': 'book_search',\\n\",\n",
    "    \"            \\n\",\n",
    "    \"            # Availability patterns\\n\",\n",
    "    \"            r'(?:is\\\\s+)?(?:the\\\\s+)?(?:book\\\\s+)?(.+?)\\\\s+(?:available|in\\\\s+stock|on\\\\s+shelf)': 'availability',\\n\",\n",
    "    \"            r'(?:when\\\\s+will\\\\s+)?(.+?)\\\\s+(?:be\\\\s+)?available': 'availability',\\n\",\n",
    "    \"            \\n\",\n",
    "    \"            # Hours patterns\\n\",\n",
    "    \"            r'(?:what\\\\s+)?(?:are\\\\s+)?(?:your\\\\s+)?(?:opening|closing)\\\\s+hours': 'hours',\\n\",\n",
    "    \"            r'(?:when\\\\s+(?:does\\\\s+)?(?:it|the\\\\s+library)\\\\s+)?(?:open|close)': 'hours',\\n\",\n",
    "    \"            r'(?:are\\\\s+)?you\\\\s+open\\\\s+(?:on\\\\s+)?(.+)': 'hours',\\n\",\n",
    "    \"            \\n\",\n",
    "    \"            # Account patterns\\n\",\n",
    "    \"            r'(?:forgot|lost|reset)\\\\s+(?:my\\\\s+)?password': 'account',\\n\",\n",
    "    \"            r'(?:how\\\\s+do\\\\s+I\\\\s+)?get\\\\s+(?:a\\\\s+)?library\\\\s+card': 'account',\\n\",\n",
    "    \"            \\n\",\n",
    "    \"            # Return patterns\\n\",\n",
    "    \"            r'(?:how\\\\s+do\\\\s+I\\\\s+)?return\\\\s+(?:the\\\\s+)?book': 'return',\\n\",\n",
    "    \"            r'late\\\\s+fee': 'return',\\n\",\n",
    "    \"            \\n\",\n",
    "    \"            # Identity patterns\\n\",\n",
    "    \"            r'(?:who\\\\s+(?:are\\\\s+)?you|what\\\\s+is\\\\s+your\\\\s+name|tell\\\\s+me\\\\s+about\\\\s+yourself)': 'identity',\\n\",\n",
    "    \"            r'(?:what\\\\s+can\\\\s+you\\\\s+do|your\\\\s+capabilities)': 'identity',\\n\",\n",
    "    \"            \\n\",\n",
    "    \"            # Borrow patterns\\n\",\n",
    "    \"            r'(?:how\\\\s+do\\\\s+I\\\\s+)?borrow|checkout|reserve|hold': 'borrow',\\n\",\n",
    "    \"        }\\n\",\n",
    "    \"    \\n\",\n",
    "    \"    def match(self, query):\\n\",\n",
    "    \"        \\\"\\\"\\\"Check if query matches any rule pattern\\\"\\\"\\\"\\n\",\n",
    "    \"        query_lower = query.lower()\\n\",\n",
    "    \"        for pattern, intent in self.rules.items():\\n\",\n",
    "    \"            if re.search(pattern, query_lower):\\n\",\n",
    "    \"                return intent, pattern\\n\",\n",
    "    \"        return None, None\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Demo rule matching\\n\",\n",
    "    \"rule_engine = RuleEngine()\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(\\\"=\\\" * 60)\\n\",\n",
    "    \"print(\\\"RULE-BASED MATCHING DEMO\\\")\\n\",\n",
    "    \"print(\\\"=\\\" * 60)\\n\",\n",
    "    \"\\n\",\n",
    "    \"test_queries = [\\n\",\n",
    "    \"    \\\"Find me a book about Python\\\",\\n\",\n",
    "    \"    \\\"Is Harry Potter available?\\\",\\n\",\n",
    "    \"    \\\"What are your opening hours?\\\",\\n\",\n",
    "    \"    \\\"I forgot my password\\\",\\n\",\n",
    "    \"    \\\"How do I return a book?\\\",\\n\",\n",
    "    \"    \\\"Who are you?\\\",\\n\",\n",
    "    \"    \\\"Can I borrow this book?\\\",\\n\",\n",
    "    \"    \\\"Search for The Great Gatsby\\\"\\n\",\n",
    "    \"]\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(\\\"\\\\n🔍 Rule Matching Results:\\\")\\n\",\n",
    "    \"print(\\\"-\\\" * 60)\\n\",\n",
    "    \"for query in test_queries:\\n\",\n",
    "    \"    intent, pattern = rule_engine.match(query)\\n\",\n",
    "    \"    status = \\\"✅\\\" if intent else \\\"❌\\\"\\n\",\n",
    "    \"    print(f\\\"\\\\n{status} Query: '{query}'\\\")\\n\",\n",
    "    \"    if intent:\\n\",\n",
    "    \"        print(f\\\"   Matched: {intent}\\\")\\n\",\n",
    "    \"        print(f\\\"   Pattern: {pattern}\\\")\\n\",\n",
    "    \"    else:\\n\",\n",
    "    \"        print(f\\\"   No rule match (will use ML)\\\")\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## Cell 9: Hybrid NLP + Rules Integration\\n\",\n",
    "    \"\\n\",\n",
    "    \"Our system combines **Machine Learning** and **Rule-Based** approaches:\\n\",\n",
    "    \"\\n\",\n",
    "    \"### Flow (from Chapter 3):\\n\",\n",
    "    \"1. **Input Query** → Preprocess\\n\",\n",
    "    \"2. **Rule Engine** → Check for exact pattern matches first\\n\",\n",
    "    \"3. **ML Classifier** → If no rule match, use intent classification\\n\",\n",
    "    \"4. **Response Generator** → Format appropriate response\\n\",\n",
    "    \"\\n\",\n",
    "    \"This hybrid approach provides:\\n\",\n",
    "    \"- High accuracy for known patterns (Rules)\\n\",\n",
    "    \"- Flexibility for new queries (ML)\\n\",\n",
    "    \"- Better coverage than either alone\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"class HybridIntentClassifier:\\n\",\n",
    "    \"    \\\"\\\"\\\"Combines ML and Rules for intent classification\\\"\\\"\\\"\\n\",\n",
    "    \"    \\n\",\n",
    "    \"    def __init__(self, ml_classifier, vectorizer, rule_engine):\\n\",\n",
    "    \"        self.classifier = ml_classifier\\n\",\n",
    "    \"        self.vectorizer = vectorizer\\n\",\n",
    "    \"        self.rule_engine = rule_engine\\n\",\n",
    "    \"    \\n\",\n",
    "    \"    def classify(self, query):\\n\",\n",
    "    \"        \\\"\\\"\\\"Hybrid classification: Rules first, then ML\\\"\\\"\\\"\\n\",\n",
    "    \"        # Step 1: Try rule-based matching first\\n\",\n",
    "    \"        rule_intent, pattern = self.rule_engine.match(query)\\n\",\n",
    "    \"        \\n\",\n",
    "    \"        if rule_intent:\\n\",\n",
    "    \"            return {\\n\",\n",
    "    \"                'intent': rule_intent,\\n\",\n",
    "    \"                'source': 'rules',\\n\",\n",
    "    \"                'confidence': 1.0,\\n\",\n",
    "    \"                'pattern': pattern\\n\",\n",
    "    \"            }\\n\",\n",
    "    \"        \\n\",\n",
    "    \"        # Step 2: Use ML classifier\\n\",\n",
    "    \"        processed = ' '.join(preprocess_text(query))\\n\",\n",
    "    \"        features = self.vectorizer.transform([processed])\\n\",\n",
    "    \"        \\n\",\n",
    "    \"        # Get prediction and probabilities\\n\",\n",
    "    \"        intent = self.classifier.predict(features)[0]\\n\",\n",
    "    \"        probabilities = self.classifier.predict_proba(features)[0]\\n\",\n",
    "    \"        confidence = max(probabilities)\\n\",\n",
    "    \"        \\n\",\n",
    "    \"        return {\\n\",\n",
    "    \"            'intent': intent,\\n\",\n",
    "    \"            'source': 'ml',\\n\",\n",
    "    \"            'confidence': confidence\\n\",\n",
    "    \"        }\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Create hybrid classifier\\n\",\n",
    "    \"hybrid_classifier = HybridIntentClassifier(classifier, tfidf_vectorizer, rule_engine)\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(\\\"=\\\" * 60)\\n\",\n",
    "    \"print(\\\"HYBRID CLASSIFIER (ML + RULES)\\\")\\n\",\n",
    "    \"print(\\\"=\\\" * 60)\\n\",\n",
    "    \"\\n\",\n",
    "    \"test_queries = [\\n\",\n",
    "    \"    \\\"Find me a book about Python\\\",\\n\",\n",
    "    \"    \\\"Hello there!\\\",\\n\",\n",
    "    \"    \\\"What time do you close?\\\",\\n\",\n",
    "    \"    \\\"Tell me about databases\\\",\\n\",\n",
    "    \"    \\\"I want to borrow 1984\\\"\\n\",\n",
    "    \"]\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(\\\"\\\\n🔬 Hybrid Classification Results:\\\")\\n\",\n",
    "    \"print(\\\"-\\\" * 60)\\n\",\n",
    "    \"for query in test_queries:\\n\",\n",
    "    \"    result = hybrid_classifier.classify(query)\\n\",\n",
    "    \"    print(f\\\"\\\\n📥 Query: '{query}'\\\")\\n\",\n",
    "    \"    print(f\\\"   🎯 Intent: {result['intent']}\\\")\\n\",\n",
    "    \"    print(f\\\"   📦 Source: {result['source']}\\\")\\n\",\n",
    "    \"    print(f\\\"   📊 Confidence: {result['confidence']:.2%}\\\")\\n\",\n",
    "    \"    if 'pattern' in result:\\n\",\n",
    "    \"        print(f\\\"   🔍 Pattern matched: {result['pattern']}\\\")\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## Cell 10: Response Generation Template\\n\",\n",
    "    \"\\n\",\n",
    "    \"After intent classification, we generate appropriate responses using templates.\\n\",\n",
    "    \"\\n\",\n",
    "    \"### Response Templates (from response_templates.json):\\n\",\n",
    "    \"- Each intent has multiple response variations\\n\",\n",
    "    \"- Templates can include dynamic placeholders\\n\",\n",
    "    \"- Responses are context-aware\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"# Response templates for each intent\\n\",\n",
    "    \"response_templates = {\\n\",\n",
    "    \"    'book_search': [\\n\",\n",
    "    \"        \\\"I found several books matching your query. Here's what I can suggest:\\\",\\n\",\n",
    "    \"        \\\"Let me search the catalog for you... Found these options:\\\",\\n\",\n",
    "    \"        \\\"Based on your search, here are some available books:\\\",\\n\",\n",
    "    \"    ],\\n\",\n",
