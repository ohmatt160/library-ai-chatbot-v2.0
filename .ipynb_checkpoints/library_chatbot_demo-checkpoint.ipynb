    "    \"    (\\\"Are there copies of Harry Potter available\\\", \\\"availability\\\"),\\n\",\n",
    "    \"    (\\\"Check if Design Patterns is available\\\", \\\"availability\\\"),\\n\",\n",
    "    \"    (\\\"I want to know if 1984 is available for checkout\\\", \\\"availability\\\"),\\n\",\n",
    "    \"    (\\\"Is there a waiting list for this book\\\", \\\"availability\\\"),\\n\",\n",
    "    \"    (\\\"When will The Hobbit be available\\\", \\\"availability\\\"),\\n\",\n",
    "    \"    \\n\",\n",
