# Environment Variables for Library AI Chatbot
# Copy this file to .env and fill in your values

# Hugging Face Token (for AI model access)
HF_TOKEN=

# Flask Secret Key
SECRET_KEY=dev-secret-key-change-in-production

# Database Settings (XAMPP MySQL defaults)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=library_chatbot_db
DB_USER=root
DB_PASSWORD=

# Alternatively, use a single DATABASE_URL
# DATABASE_URL=mysql+pymysql://root:@localhost:3306/library_chatbot_db
